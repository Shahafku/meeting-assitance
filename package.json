{
  "name": "meeting-copilot",
  "version": "0.1.0",
  "description": "Local meeting copilot: live transcription + hotkey-summoned, context-grounded suggestions. Personal tool.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness": "tsx harness/run.ts",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "0.110.0",
    "@deepgram/sdk": "5.5.0",
    "better-sqlite3": "12.11.1",
    "dotenv": "17.4.2",
    "pdf-parse": "2.4.5",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@electron/rebuild": "4.1.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.0.0",
    "electron-vite": "5.0.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
